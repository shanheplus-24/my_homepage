---
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import AnalyticsFooter from '@components/AnalyticsFooter.astro';
import MaintenancePage from '@components/MaintenancePage.astro';
import { site } from '@data/site';
import globalStyles from '@styles/global.css?inline';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => `${base}${href}`;
const favicon = withBase('/assets/generated/site-logo-nexus-white-512.png');
const maintenanceMode = !import.meta.env.DEV && import.meta.env.PUBLIC_MAINTENANCE_MODE === 'true';
const pageTitle = maintenanceMode ? `Website maintenance | ${site.name}` : title;
const pageDescription = maintenanceMode
  ? 'This academic website is temporarily offline for scheduled updates.'
  : description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    {maintenanceMode && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={favicon} type="image/png" />
    <title>{pageTitle}</title>
    <style is:global set:html={globalStyles}></style>
  </head>
  <body>
    {
      maintenanceMode ? (
        <MaintenancePage />
      ) : (
        <>
          <div class="mouse-glow" aria-hidden="true">
            <div class="mouse-glow__base"></div>
            <div class="mouse-glow__layer mouse-glow__layer--primary" data-mouse-glow="primary"></div>
            <div class="mouse-glow__layer mouse-glow__layer--secondary" data-mouse-glow="secondary"></div>
          </div>
          <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-accent focus:shadow"
          >
            Skip to content
          </a>
          <Header />
          <main id="main-content" class="pt-20">
            <slot />
          </main>
          <AnalyticsFooter />
          <Footer />
          <script is:inline>
            const revealItems = document.querySelectorAll('.reveal');
            if ('IntersectionObserver' in window && revealItems.length > 0) {
              const observer = new IntersectionObserver(
                (entries) => {
                  for (const entry of entries) {
                    if (entry.isIntersecting) {
                      entry.target.classList.add('is-visible');
                      observer.unobserve(entry.target);
                    }
                  }
                },
                { rootMargin: '0px 0px -10% 0px' },
              );
              revealItems.forEach((item) => observer.observe(item));
            } else {
              revealItems.forEach((item) => item.classList.add('is-visible'));
            }

            document.addEventListener('click', async (event) => {
              const button = event.target.closest('[data-copy-bibtex]');
              if (!button) return;
              try {
                await navigator.clipboard.writeText(button.dataset.copyBibtex);
                const original = button.textContent;
                button.textContent = 'Copied';
                window.setTimeout(() => {
                  button.textContent = original;
                }, 1400);
              } catch {
                button.textContent = 'Copy unavailable';
              }
            });
          </script>
          <script>
            import '@scripts/liquid-interactions';
          </script>
        </>
      )
    }
  </body>
</html>
