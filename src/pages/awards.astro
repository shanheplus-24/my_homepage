---
const target = `${import.meta.env.BASE_URL}about/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting to About</title>
  </head>
  <body>
    <a href={target}>About</a>
  </body>
</html>
