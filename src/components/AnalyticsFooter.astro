---
const goatCounterEndpoint = import.meta.env.PUBLIC_GOATCOUNTER_ENDPOINT || 'https://shanheplus.goatcounter.com/count';
const goatCounterSrc = import.meta.env.PUBLIC_GOATCOUNTER_SRC || '//gc.zgo.at/count.js';
---

<script is:inline async data-goatcounter={goatCounterEndpoint} src={goatCounterSrc}></script>
