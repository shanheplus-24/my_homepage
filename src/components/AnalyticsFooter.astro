---
const flagCounterUrl = import.meta.env.PUBLIC_FLAG_COUNTER_URL;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const plausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SRC || 'https://plausible.io/js/script.js';
---

<aside class="fixed bottom-4 right-4 z-30 max-w-[calc(100vw-2rem)]" aria-label="Visitor analytics">
  <details class="group rounded-[18px] border border-line bg-black/35 shadow-lg backdrop-blur-2xl">
    <summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-2 text-xs font-bold text-ink">
      <span class="size-2 rounded-full bg-accent" aria-hidden="true"></span>
      Traffic
      <span class="text-muted">{flagCounterUrl || plausibleDomain ? 'live' : 'setup'}</span>
    </summary>
    <div class="w-72 border-t border-line p-3 text-xs leading-5 text-muted">
      <p class="font-bold text-ink">Visitor analytics</p>
      <p class="mt-1">Page analytics: {plausibleDomain ? 'Plausible connected' : 'not configured'}</p>
      <p>Source locations: {flagCounterUrl ? 'flag counter connected' : 'not configured'}</p>
      {
        flagCounterUrl ? (
          <a class="mt-3 block" href={flagCounterUrl} target="_blank" rel="noopener noreferrer">
            <img
              src={flagCounterUrl}
              alt="Visitor traffic and source-country statistics"
              loading="lazy"
              class="max-w-full rounded"
            />
          </a>
        ) : (
          <p class="mt-3">
            Set <code class="font-bold text-ink">PUBLIC_FLAG_COUNTER_URL</code> to display country-source statistics.
          </p>
        )
      }
    </div>
  </details>
</aside>

{
  plausibleDomain && (
    <script is:inline defer data-domain={plausibleDomain} src={plausibleSrc}></script>
  )
}
