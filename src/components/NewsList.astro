---
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'news'>[];
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (src?: string) => src && src.startsWith('/') ? `${base}${src}` : src;
const formatDate = new Intl.DateTimeFormat('en', { month: 'short', day: 'numeric', year: 'numeric' });
---

<ol class="grid gap-5 lg:grid-cols-3" role="list">
  {
    items.map((item) => (
      <li class="news-card interactive-card flex h-full flex-col rounded-[24px] p-4 transition">
        <div class="news-card__media-stack">
          {item.data.image && (
            <div class="news-media news-media--image">
              <div class="news-media__image-panel">
                <img
                  src={withBase(item.data.image.src)}
                  alt={item.data.image.alt}
                  loading="lazy"
                  class="size-full object-contain"
                />
              </div>
            </div>
          )}
          {item.data.embeds.length > 0 && (
            <div class="grid gap-3">
              {
                item.data.embeds.map((embed) => (
                  <div class="news-media news-media--video">
                    <iframe
                      src={embed.src}
                      title={embed.title}
                      loading="lazy"
                      allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
                      allowfullscreen
                      class="news-media__iframe"
                    />
                  </div>
                ))
              }
            </div>
          )}
        </div>
        <div class="news-card__copy">
          <time class="text-sm font-bold text-accent" datetime={item.data.date.toISOString()}>
            {formatDate.format(item.data.date)}
          </time>
          <h3 class="mt-1 text-base font-bold text-ink">
            {item.data.link ? <a class="hover:text-accent" href={item.data.link}>{item.data.title}</a> : item.data.title}
          </h3>
          <p class="mt-1 text-sm leading-6 text-muted">{item.data.summary}</p>
        </div>
      </li>
    ))
  }
</ol>
