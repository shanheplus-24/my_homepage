---
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'news'>[];
}

const { items } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (src?: string) => src && src.startsWith('/') ? `${base}${src}` : src;
const isVideoFile = (src: string) => /\.(mp4|webm|ogg)(?:[?#].*)?$/i.test(src);
const getVideoMimeType = (src: string) => {
  if (/\.webm(?:[?#].*)?$/i.test(src)) return 'video/webm';
  if (/\.ogg(?:[?#].*)?$/i.test(src)) return 'video/ogg';
  return 'video/mp4';
};
---

<ol class="grid gap-5 lg:grid-cols-3" role="list">
  {
    items.map((item) => (
      <li class="news-card interactive-card flex flex-col rounded-[24px] p-4 transition">
        <div class="news-card__media-stack">
          {item.data.image && (
            <div class="news-media news-media--image">
              <div class="news-media__image-panel">
                <img
                  src={withBase(item.data.image.src)}
                  alt={item.data.image.alt}
                  loading="lazy"
                  class="size-full object-contain"
                />
              </div>
            </div>
          )}
          {item.data.embeds.length > 0 && (
            <div class="grid gap-3">
              {
                item.data.embeds.map((embed) => (
                  <div class={`news-media ${isVideoFile(embed.src) ? 'news-media--video-file' : 'news-media--video-embed'}`}>
                    {isVideoFile(embed.src) ? (
                      <video
                        class="news-media__video"
                        controls
                        preload="metadata"
                        poster={withBase(embed.poster)}
                        playsinline
                        aria-label={embed.title}
                      >
                        <source src={withBase(embed.src)} type={getVideoMimeType(embed.src)} />
                      </video>
                    ) : (
                      <iframe
                        src={embed.src}
                        title={embed.title}
                        loading="lazy"
                        allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
                        allowfullscreen
                        class="news-media__iframe"
                      />
                    )}
                  </div>
                ))
              }
            </div>
          )}
        </div>
        <div class="news-card__copy">
          <h3 class="text-base font-bold text-ink">
            {item.data.title}
          </h3>
          {item.data.summary && <p class="mt-1 text-sm leading-6 text-muted">{item.data.summary}</p>}
        </div>
      </li>
    ))
  }
</ol>
