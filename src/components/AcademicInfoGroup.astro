---
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  titleZh?: string;
  items: CollectionEntry<'academicInfo'>[];
}

const { title, titleZh, items } = Astro.props;
const sectionId = title.toLowerCase().replaceAll(' ', '-');
const isEducation = title === 'Education';
const isConference = title === 'Conference Participated';
const isSelectedPublication = title === 'Selected Publications';
const isAwards = title === 'Awards' || title === 'Selected Awards and Honors';
const isFellowships = title === 'Fellowships';
const usesInlineDescription = isAwards || isFellowships;
const formatMetaLine = (organization: string, location?: string, description?: string) => {
  const place = `${organization}${location ? `, ${location}` : ''}`.trim();
  return [place, description].filter(Boolean).join(' | ');
};
const displayOrganization = (item: CollectionEntry<'academicInfo'>) => item.data.organization;
const displayOrganizationZh = (item: CollectionEntry<'academicInfo'>) => item.data.organizationZh ?? item.data.organization;
const shouldShowDate = (item: CollectionEntry<'academicInfo'>) => item.id !== 'award-university-level-scholarships';
const splitAdvisor = (description?: string) => {
  if (!description) return { detail: '', advisor: '' };
  const match = description.match(/\s+(Advisors?:\s.+)$/);
  if (!match) return { detail: description, advisor: '' };
  return {
    detail: description.slice(0, match.index).trim(),
    advisor: match[1].trim(),
  };
};
---

<section class:list={[
  'interactive-card academic-section rounded-[30px] p-5 md:p-7',
  isEducation && 'academic-section--education',
  isAwards && 'academic-section--awards',
]} aria-labelledby={sectionId}>
  <h2 id={sectionId} class="academic-section-title text-3xl font-bold text-ink">
    <span data-lang="en">{title}</span>
    <span data-lang="zh" hidden>{titleZh ?? title}</span>
  </h2>
  <ol class:list={[
    isEducation
      ? 'education-timeline mt-7'
      : isConference
        ? 'conference-timeline mt-6'
        : isSelectedPublication
          ? 'about-selected-publications mt-6'
          : isAwards
            ? 'selected-awards-list mt-6'
            : 'mt-6 grid gap-4 md:grid-cols-2',
  ]} role="list">
    {
      items.map((item) => (
        <li class:list={[
          isEducation
            ? 'education-timeline__item'
            : isConference
              ? 'conference-timeline__item'
              : isSelectedPublication
                ? 'about-selected-publication-card'
                : isAwards
                  ? 'selected-award-item'
                  : 'academic-info-item rounded-[22px] p-4',
        ]}>
          {
            isEducation ? (
              <>
                <span class="education-node" aria-hidden="true"></span>
                <div class="education-body">
                  <p class="education-date">
                    <span data-lang="en">{item.data.date}</span>
                    <span data-lang="zh" hidden>{item.data.dateZh ?? item.data.date}</span>
                  </p>
                  <h3 class="education-title">
                    <span data-lang="en">{item.data.title}, {item.data.organization}</span>
                    <span data-lang="zh" hidden>{item.data.titleZh ?? item.data.title}, {item.data.organizationZh ?? item.data.organization}</span>
                  </h3>
                  {item.data.location && (
                    <p class="education-venue">
                      <span data-lang="en">{item.data.location}</span>
                      <span data-lang="zh" hidden>{item.data.locationZh ?? item.data.location}</span>
                    </p>
                  )}
                  {
                    item.data.description && (
                      <div class="education-description">
                        {splitAdvisor(item.data.description).detail && (
                          <p>
                            <span data-lang="en">{splitAdvisor(item.data.description).detail}</span>
                            <span data-lang="zh" hidden>{item.data.descriptionZh ?? splitAdvisor(item.data.description).detail}</span>
                          </p>
                        )}
                      </div>
                    )
                  }
                  {item.data.links.length > 0 && (
                    <div class="education-link-group" aria-label={`Advisor links for ${item.data.title}`}>
                      <span class="education-link-label">Advisor</span>
                      <ul class="education-links" role="list">
                        {
                          item.data.links.map((link) => (
                            <li>
                              <a href={link.href}>
                                {link.label}
                              </a>
                            </li>
                          ))
                        }
                      </ul>
                    </div>
                  )}
                </div>
                {item.data.logos.length > 0 && (
                  <div class:list={['education-logo-stack', item.data.logos.length > 1 && 'education-logo-stack--multiple']} aria-label={`${item.data.organization} logo`}>
                    {
                      item.data.logos.map((logo) => (
                        <span class:list={[
                          'education-logo',
                          logo.src.endsWith('national-university-of-singapore.svg') && 'education-logo--nus',
                        ]}>
                          <img src={logo.src} alt={logo.alt} loading="lazy" />
                        </span>
                      ))
                    }
                  </div>
                )}
              </>
            ) : isConference ? (
              <>
                <span class="conference-node" aria-hidden="true"></span>
                <p class="conference-date">
                  <span data-lang="en">{item.data.date}</span>
                  <span data-lang="zh" hidden>{item.data.dateZh ?? item.data.date}</span>
                </p>
                <div class="conference-body">
                  <h3>
                    <span data-lang="en">{item.data.title}</span>
                    <span data-lang="zh" hidden>{item.data.titleZh ?? item.data.title}</span>
                  </h3>
                  <p class="conference-venue">
                    <span data-lang="en">{item.data.organization}</span>
                    <span data-lang="zh" hidden>{item.data.organizationZh ?? item.data.organization}</span>
                  </p>
                  {item.data.location && (
                    <p class="conference-location">
                      <span data-lang="en">{item.data.location}</span>
                      <span data-lang="zh" hidden>{item.data.locationZh ?? item.data.location}</span>
                    </p>
                  )}
                </div>
              </>
            ) : isSelectedPublication ? (
              <>
                {item.data.image && (
                  <div class="about-selected-publication-media">
                    <img
                      src={item.data.image.src}
                      alt={item.data.image.alt}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="about-selected-publication-copy">
                  <h3>
                    <span data-lang="en">{item.data.title}</span>
                    <span data-lang="zh" hidden>{item.data.titleZh ?? item.data.title}</span>
                  </h3>
                  <p class="about-selected-publication-venue">
                    <span data-lang="en">{item.data.organization}, {item.data.date}</span>
                    <span data-lang="zh" hidden>{item.data.organizationZh ?? item.data.organization}, {item.data.dateZh ?? item.data.date}</span>
                  </p>
                  {item.data.points.length > 0 ? (
                    <>
                    <ul class="about-selected-publication-points" role="list" data-lang="en">
                      {
                        item.data.points.map((point) => (
                          <li>{point}</li>
                        ))
                      }
                    </ul>
                    <ul class="about-selected-publication-points" role="list" data-lang="zh" hidden>
                      {
                        (item.data.pointsZh.length > 0 ? item.data.pointsZh : item.data.points).map((point) => (
                          <li>{point}</li>
                        ))
                      }
                    </ul>
                    </>
                  ) : item.data.description && (
                    <p class="about-selected-publication-summary">
                      <span data-lang="en">{item.data.description}</span>
                      <span data-lang="zh" hidden>{item.data.descriptionZh ?? item.data.description}</span>
                    </p>
                  )}
                </div>
              </>
            ) : (
              <>
                <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
                  <h3 class="text-base font-bold text-ink">
                    {item.data.link ? (
                      <a class="hover:text-accent" href={item.data.link}>
                        <span data-lang="en">{item.data.title}</span>
                        <span data-lang="zh" hidden>{item.data.titleZh ?? item.data.title}</span>
                      </a>
                    ) : (
                      <>
                        <span data-lang="en">{item.data.title}</span>
                        <span data-lang="zh" hidden>{item.data.titleZh ?? item.data.title}</span>
                      </>
                    )}
                  </h3>
                  {shouldShowDate(item) && (
                    <p class="text-sm font-bold text-accent">
                      <span data-lang="en">{item.data.date}</span>
                      <span data-lang="zh" hidden>{item.data.dateZh ?? item.data.date}</span>
                    </p>
                  )}
                </div>
                <p class="mt-2 text-sm font-semibold text-muted">
                  <span data-lang="en">
                    {formatMetaLine(displayOrganization(item), item.data.location, usesInlineDescription ? item.data.description : undefined)}
                  </span>
                  <span data-lang="zh" hidden>
                    {formatMetaLine(displayOrganizationZh(item), item.data.locationZh ?? item.data.location, usesInlineDescription ? (item.data.descriptionZh ?? item.data.description) : undefined)}
                  </span>
                </p>
                {!usesInlineDescription && item.data.description && (
                  <p class="mt-3 text-sm leading-6 text-muted">
                    <span data-lang="en">{item.data.description}</span>
                    <span data-lang="zh" hidden>{item.data.descriptionZh ?? item.data.description}</span>
                  </p>
                )}
              </>
            )
          }
          {!isEducation && !isConference && !isSelectedPublication && item.data.image && (
            <img
              src={item.data.image.src}
              alt={item.data.image.alt}
              loading="lazy"
              class="mt-4 aspect-[4/3] w-full rounded-[20px] object-contain md:max-w-md"
            />
          )}
          {!isEducation && !isConference && !isSelectedPublication && item.data.links.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2" role="list" aria-label={`Links for ${item.data.title}`}>
              {
                item.data.links.map((link) => (
                  <li>
                    <a class="rounded-full bg-white/10 px-4 py-2 text-sm font-bold text-accent hover:text-accent-strong" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          )}
        </li>
      ))
    }
  </ol>
</section>
