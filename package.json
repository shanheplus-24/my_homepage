{
  "name": "academic-personal-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "cms:server": "decap-server",
    "build": "astro build",
    "build:site": "node ./scripts/build-mode.mjs site",
    "build:maintenance": "node ./scripts/build-mode.mjs maintenance",
    "deploy:site": "node ./scripts/build-mode.mjs site --deploy",
