  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "decap-server": "^3.7.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
